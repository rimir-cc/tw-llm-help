title: $:/plugins/rimir/llm-help/debug-panel-context
tags: $:/tags/rimir/llm-connect/debug-panel
panel-name: Help Context (int. data)
panel-icon: 📖
panel-order: 60
type: text/vnd.tiddlywiki

\whitespace trim

<$let count={{{ [<chatTiddler>get[llm-help-context]enlist-input[]count[]] }}}>
<%if [<count>compare:integer:gt[0]] %>
<div class="llm-chat-debug-help-ctx">
<strong><$text text=<<count>>/>&nbsp;active help context keys:</strong>
<div class="llm-chat-debug-help-ctx-keys"><$list filter="[<chatTiddler>get[llm-help-context]enlist-input[]sort[]]" variable="key"><div><$text text=<<key>>/></div></$list></div>
</div>
<%else%>
<em>(no help context active)</em>
<%endif%>
</$let>
